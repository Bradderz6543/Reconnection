---
import {
  Beer,
  CalendarDays,
  Guitar,
  Mail,
  MapPin,
  Music2,
  Phone,
  UsersRound,
} from 'lucide-astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, '')}`;

const navItems = [
  { label: "What's on", id: 'whats-on' },
  { label: 'About', id: 'about' },
  { label: 'Gallery', id: 'gallery' },
  { label: 'Contact', id: 'contact' },
];

const featureCards = [
  {
    title: 'Craft Drinks',
    text: 'Local beers, craft ales, cocktails & quality wines.',
    icon: Beer,
  },
  {
    title: 'Live Music',
    text: 'Local talent, open mic nights & special gigs.',
    icon: Guitar,
  },
  {
    title: 'Community Space',
    text: 'A welcoming space for everyone in Shipley.',
    icon: UsersRound,
  },
  {
    title: 'Events Returning',
    text: 'Music, socials & local nights coming back soon.',
    icon: CalendarDays,
  },
];

const galleryImages = [
  { src: asset('/images/interior.webp'), alt: 'Inside Reconnection — bar and seating area with warm, low lighting' },
  { src: asset('/images/bar-beers.webp'), alt: 'Taps and bottles lined up on the bar at Reconnection' },
  { src: asset('/images/exterior.webp'), alt: "Reconnection's shopfront on Westgate, Shipley" },
  { src: asset('/images/interior2.webp'), alt: 'Seating area inside Reconnection with mixed tables and chairs' },
  { src: asset('/images/party.webp'), alt: 'A busy evening at Reconnection with people gathered at the bar' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Reconnection, a cosy bar and community venue for drinks, music and events."
    />
    <link rel="preload" as="image" href={asset('/images/header.webp')} fetchpriority="high" />
    <title>Reconnection | Bar, Events & Community Venue</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Reconnection home">
        <span class="brand-main">Reconnection</span>
        <span class="brand-sub">Shipley</span>
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="main-nav"
        aria-label="Toggle menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="main-nav" id="main-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={`#${item.id}`}>{item.label}</a>
          ))
        }
      </nav>
    </header>

    <main id="top">
      <h1 class="sr-only">Reconnection Shipley — bar, events space and community venue in Shipley, West Yorkshire</h1>
      <section class="hero" id="home" style={`--hero-image: url('${asset('/images/header.webp')}')`}>
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <h2 class="hero-title">Shipley's cosy bar, events space &amp; community venue</h2>
          <p>
            Independent, welcoming and a little bit eclectic. Join us for craft drinks, live music,
            good times and great people right in the heart of Shipley.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#contact">Find us</a>
            <a class="button button-ghost" href="#whats-on">What's on</a>
          </div>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #08130c" aria-hidden="true"></div>

      <section class="features-strip" id="highlights" aria-label="Venue highlights">
        <div class="features-inner">
          {
            featureCards.map(({ title, text, icon: Icon }) => (
              <article class="feature">
                <span class="feature-icon" aria-hidden="true">
                  <Icon size={26} stroke-width={1.6} />
                </span>
                <div class="feature-text">
                  <h2>{title}</h2>
                  <p>{text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #07120b" aria-hidden="true"></div>

      <section class="events-section" id="whats-on">
        <div class="section-bar">
          <div class="section-heading">
            <Music2 size={26} aria-hidden="true" />
            <div>
              <h2>What's On</h2>
              <p>Freshly reopened. More to come.</p>
            </div>
          </div>
        </div>
        <div class="events-empty">
          <div class="events-empty-copy">
            <span class="eyebrow">Events returning soon</span>
            <h3>We’re settling back in after reopening.</h3>
            <p>
              There are no scheduled events to announce just yet, but live music and community
              nights are all part of the plan as things get moving again.
            </p>
          </div>
          <div class="events-empty-list" aria-label="Upcoming plans">
            <span><Music2 size={18} aria-hidden="true" /> Live music</span>
            <span><UsersRound size={18} aria-hidden="true" /> Community nights</span>
            <span><Mail size={18} aria-hidden="true" /> Event enquiries welcome</span>
          </div>
          <a class="button button-primary" href="mailto:info@reconnectionshipley.org.uk?subject=Event%20enquiry">Email an enquiry</a>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #07120b" aria-hidden="true"></div>

      <section class="about-band" id="about">
        <div class="about-grid">
          <div class="about-image">
            <img
              src={asset('/images/interior.webp')}
              alt="Inside Reconnection — bar and seating area with warm, low lighting"
              width="1200"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="about-copy">
            <h2>About Reconnection Shipley</h2>
            <p>
              Reconnection Shipley is more than just a bar. We're a place to meet, celebrate,
              create and belong. From live music and open mics to community meetups and relaxed
              nights out, our doors are open to all.
            </p>
            <p class="about-support">
              We champion local brewers, artists, musicians and independent spirit. Thank you
              for supporting your local.
            </p>
          </div>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: var(--paper)" aria-hidden="true"></div>

      <section class="gallery-strip" id="gallery">
        <div class="gallery-intro">
          <h2>Gallery</h2>
        </div>
        <div class="gallery-row">
          {
            galleryImages.map((image, index) => (
              <a
                href={image.src}
                class="gallery-tile"
                data-gallery-index={index}
                target="_blank"
                rel="noopener"
                aria-label={`View photo: ${image.alt}`}
              >
                <img
                  src={image.src}
                  alt={image.alt}
                  width="1200"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ))
          }
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: var(--coal)" aria-hidden="true"></div>

      <section class="contact-panel" id="contact">
        <div class="contact-details">
          <p class="eyebrow">Come Say Hello</p>
          <p class="open-status" data-open-status>
            <span class="status-dot" aria-hidden="true"></span>
            <span>Checking opening hours</span>
          </p>
          <ul class="contact-list">
            <li>
              <MapPin size={18} aria-hidden="true" />
              <a
                href="https://www.google.com/maps/dir/?api=1&destination=41+Westgate+Shipley+BD18+3QX"
                target="_blank"
                rel="noopener"
              >
                41 Westgate, Shipley,<br />West Yorkshire, BD18 3QX
              </a>
            </li>
            <li>
              <Phone size={18} aria-hidden="true" />
              <a href="tel:+447399036526">07399 036526</a>
            </li>
            <li>
              <Mail size={18} aria-hidden="true" />
              <a href="mailto:info@reconnectionshipley.org.uk">info@reconnectionshipley.org.uk</a>
            </li>
          </ul>
          <div class="hours-list" aria-label="Opening hours">
            <dl>
              <div><dt>Mon</dt><dd>Closed</dd></div>
              <div><dt>Tue – Thu</dt><dd>3pm – 11pm</dd></div>
              <div><dt>Fri – Sat</dt><dd>12pm – 11pm</dd></div>
              <div><dt>Sun</dt><dd>12pm – 6pm</dd></div>
            </dl>
          </div>
        </div>
        <div class="map-card">
          <iframe
            title="Map showing Reconnection Shipley"
            src="https://www.google.com/maps?q=41%20Westgate%2C%20Shipley%2C%20BD18%203QX&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <a
            class="map-directions"
            href="https://www.google.com/maps/dir/?api=1&destination=41+Westgate+Shipley+BD18+3QX"
            target="_blank"
            rel="noopener"
          >
            <MapPin size={16} aria-hidden="true" /> Get directions
          </a>
        </div>
      </section>
    </main>

    <dialog class="gallery-dialog" aria-label="Gallery viewer">
      <button class="gallery-dialog-close" type="button" aria-label="Close gallery">×</button>
      <button class="gallery-dialog-nav gallery-dialog-prev" type="button" aria-label="Previous image">‹</button>
      <figure class="gallery-dialog-figure">
        <img class="gallery-dialog-img" alt="" />
        <figcaption class="gallery-dialog-caption"></figcaption>
      </figure>
      <button class="gallery-dialog-nav gallery-dialog-next" type="button" aria-label="Next image">›</button>
    </dialog>

    <footer class="site-footer">
      <div class="footer-row">
        <a class="brand footer-brand" href="#top" aria-label="Reconnection home">
          <span class="brand-main">Reconnection</span>
          <span class="brand-sub">Shipley</span>
        </a>
        <nav class="footer-nav" aria-label="Footer navigation">
          {
            navItems.map((item) => (
              <a href={`#${item.id}`}>{item.label}</a>
            ))
          }
        </nav>
        <p class="copyright">&copy; 2026 Reconnection Shipley.<br />All rights reserved.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('.main-nav');
      const navLinks = [...document.querySelectorAll('.main-nav a')];
      const sectionLinks = [...document.querySelectorAll('a[href^="#"]')];
      const header = document.querySelector('.site-header');
      const openStatus = document.querySelector('[data-open-status]');
      const sections = navLinks
        .map((link) => {
          const id = link.getAttribute('href')?.slice(1);
          const section = id ? document.getElementById(id) : null;
          return section ? { id, link, section } : null;
        })
        .filter(Boolean);

      const setActiveLink = (id) => {
        navLinks.forEach((link) => {
          const isActive = link.getAttribute('href') === `#${id}`;
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const updateActiveSection = () => {
        const headerHeight = header?.getBoundingClientRect().height ?? 0;
        const scrollPosition = window.scrollY + headerHeight + 24;
        const activeSection = sections
          .filter(({ section }) => section.offsetTop <= scrollPosition)
          .at(-1);

        setActiveLink(activeSection?.id ?? '');
      };

      toggle?.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        nav?.classList.toggle('is-open', !isOpen);
        toggle.blur();
      });

      sectionLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          const id = link.getAttribute('href')?.slice(1);
          const section = id ? document.getElementById(id) : null;

          if (nav?.contains(link)) {
            toggle?.setAttribute('aria-expanded', 'false');
            nav.classList.remove('is-open');
          }

          if (!id || !section) return;

          event.preventDefault();
          setActiveLink(id);

          const headerHeight = header?.getBoundingClientRect().height ?? 0;
          const targetTop = section.getBoundingClientRect().top + window.scrollY - headerHeight + 12;

          window.history.pushState(null, '', `#${id}`);
          window.scrollTo({
            top: targetTop,
            behavior: 'smooth',
          });
        });
      });

      updateActiveSection();
      window.addEventListener('scroll', updateActiveSection, { passive: true });
      window.addEventListener('resize', updateActiveSection);

      const openingHours = [
        null,
        { open: '15:00', close: '23:00' },
        { open: '15:00', close: '23:00' },
        { open: '15:00', close: '23:00' },
        { open: '12:00', close: '23:00' },
        { open: '12:00', close: '23:00' },
        { open: '12:00', close: '18:00' },
      ];

      const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

      const toMinutes = (time) => {
        const [hours, minutes] = time.split(':').map(Number);
        return hours * 60 + minutes;
      };

      const toDisplayTime = (time) => {
        const [hourString, minuteString] = time.split(':');
        const hour = Number(hourString);
        const suffix = hour >= 12 ? 'pm' : 'am';
        const displayHour = hour % 12 || 12;
        return `${displayHour}${minuteString === '00' ? '' : `:${minuteString}`}${suffix}`;
      };

      const updateOpenStatus = () => {
        if (!openStatus) return;

        const now = new Date();
        const currentDay = now.getDay();
        const currentMinutes = now.getHours() * 60 + now.getMinutes();
        const today = openingHours[currentDay === 0 ? 6 : currentDay - 1];

        if (today && currentMinutes >= toMinutes(today.open) && currentMinutes < toMinutes(today.close)) {
          openStatus.classList.add('is-open');
          openStatus.classList.remove('is-closed');
          openStatus.querySelector('span:last-child').textContent = `Open now until ${toDisplayTime(today.close)}`;
          return;
        }

        for (let offset = 0; offset < 7; offset += 1) {
          const date = new Date(now);
          date.setDate(now.getDate() + offset);
          const day = date.getDay();
          const schedule = openingHours[day === 0 ? 6 : day - 1];
          const opensLaterToday = offset === 0 && schedule && currentMinutes < toMinutes(schedule.open);

          if (schedule && (offset > 0 || opensLaterToday)) {
            const label = offset === 0 ? 'today' : dayNames[day];
            openStatus.classList.add('is-closed');
            openStatus.classList.remove('is-open');
            openStatus.querySelector('span:last-child').textContent =
              `Closed now, opens ${label} at ${toDisplayTime(schedule.open)}`;
            return;
          }
        }
      };

      updateOpenStatus();
      setInterval(updateOpenStatus, 60000);

      const galleryTiles = [...document.querySelectorAll('.gallery-tile')];
      const galleryDialog = document.querySelector('.gallery-dialog');
      const galleryDialogImg = document.querySelector('.gallery-dialog-img');
      const galleryDialogCaption = document.querySelector('.gallery-dialog-caption');
      const galleryDialogClose = document.querySelector('.gallery-dialog-close');
      const galleryDialogPrev = document.querySelector('.gallery-dialog-prev');
      const galleryDialogNext = document.querySelector('.gallery-dialog-next');

      const galleryItems = galleryTiles.map((tile) => {
        const img = tile.querySelector('img');
        return {
          src: img?.getAttribute('src') ?? tile.getAttribute('href') ?? '',
          alt: img?.getAttribute('alt') ?? '',
        };
      });

      let galleryIndex = 0;

      const renderGallery = () => {
        const item = galleryItems[galleryIndex];
        if (!item || !galleryDialogImg) return;
        galleryDialogImg.setAttribute('src', item.src);
        galleryDialogImg.setAttribute('alt', item.alt);
        if (galleryDialogCaption) galleryDialogCaption.textContent = item.alt;
      };

      const stepGallery = (delta) => {
        if (!galleryItems.length) return;
        galleryIndex = (galleryIndex + delta + galleryItems.length) % galleryItems.length;
        renderGallery();
      };

      const openGallery = (index) => {
        if (!galleryDialog || typeof galleryDialog.showModal !== 'function') return false;
        galleryIndex = index;
        renderGallery();
        galleryDialog.showModal();
        return true;
      };

      galleryTiles.forEach((tile, index) => {
        tile.addEventListener('click', (event) => {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.button === 1) return;
          if (openGallery(index)) {
            event.preventDefault();
          }
        });
      });

      galleryDialogClose?.addEventListener('click', () => galleryDialog?.close());
      galleryDialogPrev?.addEventListener('click', () => stepGallery(-1));
      galleryDialogNext?.addEventListener('click', () => stepGallery(1));

      galleryDialog?.addEventListener('click', (event) => {
        if (event.target === galleryDialog) galleryDialog.close();
      });

      document.addEventListener('keydown', (event) => {
        if (!galleryDialog?.open) return;
        if (event.key === 'ArrowLeft') stepGallery(-1);
        if (event.key === 'ArrowRight') stepGallery(1);
      });
    </script>
  </body>
</html>
