---
import {
  Beer,
  CalendarDays,
  Guitar,
  Mail,
  MapPin,
  Music2,
  Phone,
  UsersRound,
  Wine,
} from 'lucide-astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, '')}`;

const navItems = [
  { label: "What's on", id: 'whats-on', mobileOrder: 2 },
  { label: 'Drinks', id: 'drinks', mobileOrder: 1 },
  { label: 'About', id: 'about', mobileOrder: 3 },
  { label: 'Private hire', id: 'private-hire', mobileOrder: 4 },
  { label: 'Gallery', id: 'gallery', mobileOrder: 5 },
  { label: 'Contact', id: 'contact', mobileOrder: 6 },
];

const featureCards = [
  {
    title: 'Craft Drinks',
    text: 'Local beers, craft ales, cocktails & quality wines.',
    icon: Beer,
  },
  {
    title: 'Live Music',
    text: 'Local talent, open mic nights & special gigs.',
    icon: Guitar,
  },
  {
    title: 'Community Space',
    text: 'A welcoming space for everyone in Shipley.',
    icon: UsersRound,
  },
  {
    title: 'Private Hire',
    text: 'Parties, meetings & events — we’ve got you covered.',
    icon: Wine,
  },
];

const galleryImages = [
  asset('/images/interior.webp'),
  asset('/images/bar-beers.webp'),
  asset('/images/exterior.webp'),
  asset('/images/interior2.webp'),
  asset('/images/party.webp'),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Reconnection, a cosy bar and community venue for drinks, music, events and private hire."
    />
    <link rel="preload" as="image" href={asset('/images/header.webp')} fetchpriority="high" />
    <title>Reconnection | Bar, Events & Community Venue</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Reconnection home">
        <span class="brand-main">Reconnection</span>
        <span class="brand-sub">Shipley</span>
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="main-nav"
        aria-label="Toggle menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="main-nav" id="main-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={`#${item.id}`} style={`--mobile-order: ${item.mobileOrder}`}>{item.label}</a>
          ))
        }
      </nav>
    </header>

    <main id="top">
      <section class="hero" id="home" style={`--hero-image: url('${asset('/images/header.webp')}')`}>
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <h1>Shipley's cosy bar, events space &amp; community venue</h1>
          <p>
            Independent, welcoming and a little bit eclectic. Join us for craft drinks, live music,
            good times and great people right in the heart of Shipley.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#whats-on">What's on</a>
            <a class="button button-ghost" href="#contact">Contact</a>
          </div>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #08130c" aria-hidden="true"></div>

      <section class="features-strip" id="drinks" aria-label="Venue highlights">
        <div class="features-inner">
          {
            featureCards.map(({ title, text, icon: Icon }) => (
              <article class="feature">
                <span class="feature-icon" aria-hidden="true">
                  <Icon size={26} stroke-width={1.6} />
                </span>
                <div class="feature-text">
                  <h2>{title}</h2>
                  <p>{text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #07120b" aria-hidden="true"></div>

      <section class="events-section" id="whats-on">
        <div class="section-bar">
          <div class="section-heading">
            <Music2 size={26} aria-hidden="true" />
            <div>
              <h2>What's On</h2>
              <p>Freshly reopened. More to come.</p>
            </div>
          </div>
        </div>
        <div class="events-empty">
          <div class="events-empty-copy">
            <span class="eyebrow">Events returning soon</span>
            <h3>We’re settling back in after reopening.</h3>
            <p>
              There are no scheduled events to announce just yet, but live music, community nights
              and private hire options are all part of the plan as things get moving again.
            </p>
          </div>
          <div class="events-empty-list" aria-label="Upcoming plans">
            <span><Music2 size={18} aria-hidden="true" /> Live music</span>
            <span><UsersRound size={18} aria-hidden="true" /> Community nights</span>
            <span><Mail size={18} aria-hidden="true" /> Event enquiries welcome</span>
          </div>
          <a class="button button-primary" href="#contact">Contact us</a>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: #07120b" aria-hidden="true"></div>

      <section class="about-band" id="about">
        <div class="about-grid">
          <div class="about-image">
            <img
              src={asset('/images/interior.webp')}
              alt="Reconnection interior"
              width="1200"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="about-copy">
            <h2>About Reconnection<br />Shipley</h2>
            <p>
              Reconnection Shipley is more than just a bar. We're a place to meet, celebrate,
              create and belong. From live music and open mics to community meetups and private
              parties, our doors are open to all.
            </p>
            <a class="button button-primary" href="#contact">Learn more about us</a>
          </div>
          <aside class="support-card" aria-label="Support local">
            <div class="support-card-inner">
              <span class="support-mark" aria-hidden="true">
                <Music2 size={22} stroke-width={1.6} />
              </span>
              <h3>Support Local</h3>
              <p>
                We champion local brewers, artists, musicians and independent spirit.
              </p>
              <p class="support-signoff">Thank you for supporting your local.</p>
            </div>
          </aside>
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: var(--paper)" aria-hidden="true"></div>

      <section class="gallery-strip" id="gallery">
        <div class="gallery-intro">
          <h2>Gallery</h2>
        </div>
        <div class="gallery-row">
          {
            galleryImages.map((image, index) => (
              <a href={image} aria-label={`Open gallery image ${index + 1}`}>
                <img
                  src={image}
                  alt={`Reconnection gallery image ${index + 1}`}
                  width="1200"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ))
          }
        </div>
      </section>

      <div class="paper-tear" style="--tear-color: var(--coal)" aria-hidden="true"></div>

      <section class="contact-panel" id="contact">
        <div class="contact-details">
          <p class="eyebrow">Come Say Hello</p>
          <ul class="contact-list">
            <li><MapPin size={18} /> <span>41 Westgate, Shipley,<br />West Yorkshire, BD18 3QX</span></li>
            <li><Phone size={18} /> <span>07399 036526</span></li>
            <li><Mail size={18} /> <span>info@reconnectionshipley.org.uk</span></li>
          </ul>
          <div class="hours-list" aria-label="Opening hours">
            <dl>
              <div><dt>Mon</dt><dd>Closed</dd></div>
              <div><dt>Tue – Thu</dt><dd>3pm – 11pm</dd></div>
              <div><dt>Fri – Sat</dt><dd>12pm – 11pm</dd></div>
              <div><dt>Sun</dt><dd>12pm – 6pm</dd></div>
            </dl>
          </div>
          <p class="open-status" data-open-status>
            <span class="status-dot" aria-hidden="true"></span>
            <span>Checking opening hours</span>
          </p>
        </div>
        <div class="map-card" aria-hidden="true">
          <iframe
            title="Map showing Reconnection Shipley"
            src="https://www.google.com/maps?q=41%20Westgate%2C%20Shipley%2C%20BD18%203QX&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-row">
        <a class="brand footer-brand" href="#top" aria-label="Reconnection home">
          <span class="brand-main">Reconnection</span>
          <span class="brand-sub">Shipley</span>
        </a>
        <nav class="footer-nav" aria-label="Footer navigation">
          {
            navItems.map((item) => (
              <a href={`#${item.id}`}>{item.label}</a>
            ))
          }
        </nav>
        <p class="copyright">&copy; 2026 Reconnection Shipley.<br />All rights reserved.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('.main-nav');
      const navLinks = [...document.querySelectorAll('.main-nav a')];
      const sectionLinks = [...document.querySelectorAll('a[href^="#"]')];
      const header = document.querySelector('.site-header');
      const openStatus = document.querySelector('[data-open-status]');
      const sections = navLinks
        .map((link) => {
          const id = link.getAttribute('href')?.slice(1);
          const section = id ? document.getElementById(id) : null;
          return section ? { id, link, section } : null;
        })
        .filter(Boolean);

      const setActiveLink = (id) => {
        navLinks.forEach((link) => {
          const isActive = link.getAttribute('href') === `#${id}`;
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      toggle?.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        nav?.classList.toggle('is-open', !isOpen);
        toggle.blur();
      });

      sectionLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          const id = link.getAttribute('href')?.slice(1);
          const section = id ? document.getElementById(id) : null;

          if (nav?.contains(link)) {
            toggle?.setAttribute('aria-expanded', 'false');
            nav.classList.remove('is-open');
          }

          if (!id || !section) return;

          event.preventDefault();
          setActiveLink(id);

          const headerHeight = header?.getBoundingClientRect().height ?? 0;
          const targetTop = section.getBoundingClientRect().top + window.scrollY - headerHeight + 12;

          window.history.pushState(null, '', `#${id}`);
          window.scrollTo({
            top: targetTop,
            behavior: 'smooth',
          });
        });
      });

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible?.target?.id) setActiveLink(visible.target.id);
        },
        {
          rootMargin: '-35% 0px -50% 0px',
          threshold: [0.1, 0.25, 0.5, 0.75],
        },
      );

      sections.forEach(({ section }) => observer.observe(section));

      const openingHours = [
        null,
        { open: '15:00', close: '23:00' },
        { open: '15:00', close: '23:00' },
        { open: '15:00', close: '23:00' },
        { open: '12:00', close: '23:00' },
        { open: '12:00', close: '23:00' },
        { open: '12:00', close: '18:00' },
      ];

      const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

      const toMinutes = (time) => {
        const [hours, minutes] = time.split(':').map(Number);
        return hours * 60 + minutes;
      };

      const toDisplayTime = (time) => {
        const [hourString, minuteString] = time.split(':');
        const hour = Number(hourString);
        const suffix = hour >= 12 ? 'pm' : 'am';
        const displayHour = hour % 12 || 12;
        return `${displayHour}${minuteString === '00' ? '' : `:${minuteString}`}${suffix}`;
      };

      const updateOpenStatus = () => {
        if (!openStatus) return;

        const now = new Date();
        const currentDay = now.getDay();
        const currentMinutes = now.getHours() * 60 + now.getMinutes();
        const today = openingHours[currentDay === 0 ? 6 : currentDay - 1];

        if (today && currentMinutes >= toMinutes(today.open) && currentMinutes < toMinutes(today.close)) {
          openStatus.classList.add('is-open');
          openStatus.classList.remove('is-closed');
          openStatus.querySelector('span:last-child').textContent = `Open now until ${toDisplayTime(today.close)}`;
          return;
        }

        for (let offset = 0; offset < 7; offset += 1) {
          const date = new Date(now);
          date.setDate(now.getDate() + offset);
          const day = date.getDay();
          const schedule = openingHours[day === 0 ? 6 : day - 1];
          const opensLaterToday = offset === 0 && schedule && currentMinutes < toMinutes(schedule.open);

          if (schedule && (offset > 0 || opensLaterToday)) {
            const label = offset === 0 ? 'today' : dayNames[day];
            openStatus.classList.add('is-closed');
            openStatus.classList.remove('is-open');
            openStatus.querySelector('span:last-child').textContent =
              `Closed now, opens ${label} at ${toDisplayTime(schedule.open)}`;
            return;
          }
        }
      };

      updateOpenStatus();
      setInterval(updateOpenStatus, 60000);
    </script>
  </body>
</html>
